<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" styleClass="responsive-page" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.qq.recruitment.controller.MyApplicationsController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <Label text="My Applications" styleClass="page-title"/>

    <TableView fx:id="appTable" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="jobIdColumn" text="Job ID" prefWidth="150"/>
            <TableColumn fx:id="jobTitleColumn" text="Job Title" prefWidth="200"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
            <TableColumn fx:id="appliedAtColumn" text="Applied At" prefWidth="150"/>
            <TableColumn fx:id="actionColumn" text="Action" minWidth="260" prefWidth="280"/>
        </columns>
    </TableView>

</VBox>
