<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="10" styleClass="responsive-page" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.qq.recruitment.controller.ApplicantController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Available Jobs" styleClass="page-title"/>
        <HBox HBox.hgrow="ALWAYS" />
        <Label fx:id="workloadStatusLabel" text="My Workload: -" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    </HBox>

    <TableView fx:id="jobTable" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="jobIdColumn" text="Job ID" prefWidth="90"/>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="120"/>
            <TableColumn fx:id="categoryColumn" text="Category / Capacity" prefWidth="150"/>
            <TableColumn fx:id="postedByColumn" text="Posted By" prefWidth="120"/>
            <TableColumn fx:id="skillsColumn" text="Required Skills" prefWidth="120"/>
            <TableColumn fx:id="requirementsColumn" text="Requirements" prefWidth="160"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="130"/>
            <TableColumn fx:id="favoriteColumn" text="Favorite" minWidth="90" prefWidth="100"/>
            <TableColumn fx:id="actionColumn" text="Action" minWidth="100" prefWidth="110"/>
        </columns>
    </TableView>

</VBox>
