<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.SplitPane?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.qq.recruitment.controller.ScreeningController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Application Screening" styleClass="page-title"/>
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="Batch Accept" fx:id="batchAcceptBtn" onAction="#handleBatchAccept" styleClass="btn-success"/>
        <Button text="Batch Reject" fx:id="batchRejectBtn" onAction="#handleBatchReject" styleClass="btn-danger"/>
    </HBox>

    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.7">
        <TableView fx:id="applicationTable">
            <columns>
                <TableColumn fx:id="selectColumn" text="Select" prefWidth="70"/>
                <TableColumn fx:id="jobIdColumn" text="Job ID" prefWidth="120"/>
                <TableColumn fx:id="jobTitleColumn" text="Job Title" prefWidth="160"/>
                <TableColumn fx:id="applicantColumn" text="Applicant" prefWidth="120"/>
                <TableColumn fx:id="workloadColumn" text="Workload" prefWidth="90"/>
                <TableColumn fx:id="capacityColumn" text="Capacity" prefWidth="90"/>
                <TableColumn fx:id="appliedAtColumn" text="Applied At" prefWidth="130"/>
                <TableColumn fx:id="scoreColumn" text="AI Score" prefWidth="80"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                <TableColumn fx:id="actionColumn" text="Action" prefWidth="150"/>
            </columns>
        </TableView>

        <VBox fx:id="detailDrawer" spacing="10" styleClass="detail-panel">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Application Details" styleClass="panel-section-title"/>
            <Label fx:id="detailNameLabel" text="Name: -" styleClass="text-secondary"/>
            <Label fx:id="detailMajorLabel" text="Major: -" styleClass="text-secondary"/>
            <Label fx:id="detailSkillsLabel" text="Skills: -" wrapText="true" styleClass="text-secondary"/>
            <Label fx:id="detailWorkloadLabel" text="Current Workload: -" styleClass="text-secondary"/>
            <Label fx:id="detailResumeLabel" text="Resume: -" wrapText="true" styleClass="text-secondary"/>
            <HBox spacing="8">
                <Button fx:id="openResumeBtn" text="Open Resume" onAction="#handleOpenResume" styleClass="btn-primary"/>
                <Button fx:id="saveResumeBtn" text="Save Resume As" onAction="#handleSaveResumeAs" styleClass="btn-primary"/>
            </HBox>
            <Label text="AI Analysis:" styleClass="panel-section-title"/>
            <Label fx:id="detailAiAnalysisLabel" text="-" wrapText="true" VBox.vgrow="ALWAYS" styleClass="text-secondary"/>
        </VBox>
    </SplitPane>

</VBox>
