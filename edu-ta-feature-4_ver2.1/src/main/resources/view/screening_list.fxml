<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.qq.recruitment.controller.ScreeningController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Application Screening">
            <font>
                <Font name="Tahoma" size="20"/>
            </font>
        </Label>
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="Batch Accept" fx:id="batchAcceptBtn" onAction="#handleBatchAccept" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Batch Reject" fx:id="batchRejectBtn" onAction="#handleBatchReject" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
    </HBox>

    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.7">
        <TableView fx:id="applicationTable">
            <columns>
                <TableColumn fx:id="jobIdColumn" text="Job ID" prefWidth="120"/>
                <TableColumn fx:id="applicantColumn" text="Applicant" prefWidth="120"/>
                <TableColumn fx:id="appliedAtColumn" text="Applied At" prefWidth="130"/>
                <TableColumn fx:id="scoreColumn" text="AI Score" prefWidth="80"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                <TableColumn fx:id="actionColumn" text="Action" prefWidth="150"/>
            </columns>
        </TableView>

        <VBox fx:id="detailDrawer" spacing="10" style="-fx-background-color: #f4f4f4; -fx-border-color: #ccc; -fx-border-width: 1;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Application Details">
                <font><Font name="Tahoma" size="16"/></font>
            </Label>
            <Label fx:id="detailNameLabel" text="Name: -"/>
            <Label fx:id="detailMajorLabel" text="Major: -"/>
            <Label fx:id="detailSkillsLabel" text="Skills: -" wrapText="true"/>
            <Label fx:id="detailWorkloadLabel" text="Current Workload: -"/>
            <Label fx:id="detailResumeLabel" text="Resume: -" wrapText="true"/>
            <Label text="AI Analysis:"/>
            <Label fx:id="detailAiAnalysisLabel" text="-" wrapText="true" VBox.vgrow="ALWAYS"/>
        </VBox>
    </SplitPane>

</VBox>
