<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.qq.recruitment.controller.MainController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="top-bar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="24.0" right="24.0" top="12.0" />
            </padding>
            <Label text="Edu-TA Recruitment" styleClass="title-label" minWidth="0.0" HBox.hgrow="ALWAYS" />
            <HBox HBox.hgrow="ALWAYS" />
            <Label fx:id="userLabel" styleClass="user-label" text="Welcome, User" minWidth="0.0" />
            <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-btn" text="Logout" />
        </HBox>
    </top>
    <left>
        <VBox fx:id="sidebar" minWidth="160.0" prefWidth="200.0" maxWidth="220.0" spacing="0.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </left>
    <center>
        <VBox fx:id="contentArea" alignment="CENTER" styleClass="content-area" BorderPane.alignment="CENTER">
             <Label text="Please select an option from the menu." textFill="#888888">
                 <font>
                     <javafx.scene.text.Font size="15.0" />
                 </font>
             </Label>
        </VBox>
    </center>
</BorderPane>
