<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="responsive-page" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.qq.recruitment.controller.JobController">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>
    <padding>
        <Insets bottom="25" left="25" right="25" top="25"/>
    </padding>

    <Label text="Post New Job" styleClass="page-title"/>

    <VBox styleClass="card" spacing="16" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="24" left="24" right="24" top="24"/>
        </padding>

        <GridPane hgap="16" vgap="14" maxWidth="1.7976931348623157E308">
            <columnConstraints>
                <ColumnConstraints minWidth="150.0" hgrow="NEVER"/>
                <ColumnConstraints minWidth="260.0" hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Job Title:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="text-secondary"/>
            <TextField fx:id="titleField" promptText="Enter job title" styleClass="form-field" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="text-secondary"/>
            <TextField fx:id="categoryField" promptText="e.g., Teaching, Event" styleClass="form-field" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="text-secondary"/>
            <TextArea fx:id="descriptionArea" prefRowCount="4" wrapText="true" styleClass="form-field" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Requirements:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="text-secondary"/>
            <TextArea fx:id="requirementsArea" prefRowCount="4" wrapText="true" styleClass="form-field" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Required Skills:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="text-secondary"/>
            <TextField fx:id="skillsField" promptText="Comma separated" styleClass="form-field" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Label text="Max Applicants (1-30):" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="text-secondary"/>
            <TextField fx:id="maxApplicantsField" promptText="Default 10" styleClass="form-field" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <Button text="Post Job" onAction="#handlePostJob" styleClass="btn-primary" GridPane.columnIndex="1" GridPane.rowIndex="6" GridPane.halignment="RIGHT"/>
        </GridPane>
    </VBox>
</VBox>
